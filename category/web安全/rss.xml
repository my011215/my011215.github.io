&lt;li&gt;&lt;a href=&#34;#%E8%BF%9C%E7%A8%8B%E5%91%BD%E4%BB%A4%E6%89%A7%E8%A1%8C-1&#34;&gt;远程命令执行&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#php%E5%8F%8D%E5%BA%8F%E5%88%97%E5%8C%96&#34;&gt;（php）反序列化&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#java%E5%8F%8D%E5%BA%8F%E5%88%97%E5%8C%96&#34;&gt;（java）反序列化&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#xxe&#34;&gt;xxe&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#jwt%E5%AE%89%E5%85%A8%E5%8F%8A%E9%A2%84%E7%BC%96%E8%AF%91case%E6%B3%A8%E5%85%A5&#34;&gt;（JWT）安全及预编译（CASE）注入&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#java%E7%9B%AE%E5%BD%95%E9%81%8D%E5%8E%86&#34;&gt;（java）目录遍历&lt;/a&gt;&lt;/li&gt;
