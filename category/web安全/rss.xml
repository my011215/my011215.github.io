&lt;li&gt;&lt;a href=&#34;#%E6%8E%A8%E6%96%87&#34;&gt;推文&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%9B%BE%E7%89%87%E4%B8%8A%E4%BC%A0&#34;&gt;图片上传&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#xss&#34;&gt;XSS&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#csrf&#34;&gt;CSRF&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E4%BF%AE%E5%A4%8D%E5%BB%BA%E8%AE%AE&#34;&gt;修复建议&lt;/a&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;#%E4%BA%A4%E6%98%93%E9%80%BB%E8%BE%91%E6%BC%8F%E6%B4%9E-1&#34;&gt;交易逻辑漏洞&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#csrf-1&#34;&gt;CSRF&lt;/a&gt;&lt;/li&gt;
