        <item>
            <guid isPermalink="true">https://my011215.github.io/2023/02/14/Penetration%20testing/%E5%85%B6%E4%BB%96%E6%BC%8F%E6%B4%9E/</guid>
            <title>其他漏洞</title>
            <link>https://my011215.github.io/2023/02/14/Penetration%20testing/%E5%85%B6%E4%BB%96%E6%BC%8F%E6%B4%9E/</link>
            <pubDate>Tue, 14 Feb 2023 18:12:30 +0800</pubDate>
            <description><![CDATA[ &lt;!-- toc --&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%85%B6%E4%BB%96%E6%BC%8F%E6%B4%9E&#34;&gt;其他漏洞&lt;/a&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;#%E6%93%8D%E4%BD%9C%E7%B3%BB%E7%BB%9F%E6%BC%8F%E6%B4%9E&#34;&gt;操作系统漏洞&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#web%E5%BA%94%E7%94%A8%E6%BC%8F%E6%B4%9E&#34;&gt;（Web）应用漏洞&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#app%E5%BA%94%E7%94%A8%E6%BC%8F%E6%B4%9E&#34;&gt;（APP）应用漏洞&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#api%E6%8E%A5%E5%8F%A3%E6%9C%8D%E5%8A%A1%E6%BC%8F%E6%B4%9E&#34;&gt;（API）接口服务漏洞&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#waf%E7%BB%95%E8%BF%87%E4%BF%A1%E6%81%AF%E6%94%B6%E9%9B%86&#34;&gt;（WAF）绕过信息收集&lt;/a&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;#%E4%BB%A3%E7%90%86%E6%B1%A0&#34;&gt;代理池&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E6%8C%87%E7%BA%B9%E6%8E%A2%E9%92%88&#34;&gt;指纹探针&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E4%BB%A3%E7%A0%81%E6%B7%B7%E6%B7%86&#34;&gt;代码混淆&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E6%B3%A8%E5%85%A5%E4%B8%8A%E4%BC%A0&#34;&gt;注入上传&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
